# Copy to .env and fill in real values. NEVER commit the real .env.
APP_NAME=vedic-astro-backend
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
DEBUG=true

# MongoDB (local Compass or Atlas). Atlas enables $vectorSearch; local falls back to text search.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=astro

# LLM — OpenAI-compatible endpoint (Groq used in dev). Synthesis falls back to the reasoning model on rate limit.
LLM_API_KEY=your-groq-or-openai-key
LLM_BASE_URL=https://api.groq.com/openai/v1
OPENAI_SYNTHESIS_MODEL=llama-3.3-70b-versatile
OPENAI_CLASSIFIER_MODEL=llama-3.3-70b-versatile
OPENAI_REASONING_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=optional-openai-key

# Embeddings — separate provider (Jina has free embeddings; Groq has none).
EMBEDDING_API_KEY=your-jina-or-openai-embedding-key
EMBEDDING_BASE_URL=https://api.jina.ai/v1
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSIONS=1024

# Prokerala (chart + transit data)
PROKERALA_CLIENT_ID=your-prokerala-client-id
PROKERALA_CLIENT_SECRET=your-prokerala-client-secret
PROKERALA_TOKEN_URL=https://api.prokerala.com/token
PROKERALA_BASE_URL=https://api.prokerala.com/v2/astrology

# Retrieval / prompt budgets
MAX_RETRIEVAL_CHUNKS=8
MAX_CONVERSATION_TURNS=4
MAX_SESSION_SUMMARIES=5
PROMPT_TOKEN_BUDGET=4000
